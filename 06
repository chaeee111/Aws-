    "# ✏️ STEP 2C: 일반 문서 처리 함수 (FORMS + QUERIES)\n",
    "def process_general(doc_bytes, custom_queries=None):\n",
    "    # 기본 쿼리\n",
    "    if custom_queries is None:\n",
    "        custom_queries = [\n",
    "            {'Text': 'What is the date?', 'Alias': 'DATE'},\n",
